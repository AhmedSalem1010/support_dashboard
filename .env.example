# عنوان API المصادقة (OTP, auth, users/profile)
NEXT_PUBLIC_AUTH_API_BASE_URL=https://api.thecleanlife.dev

# عنوان الباكند المحلي (باقي الـ endpoints)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5050

# توكن المصادقة - يُرسل تلقائياً مع كل طلب في header: Authorization: Bearer {token}
NEXT_PUBLIC_AUTH_TOKEN=your_jwt_token_here
